<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- MediaRouteButton resolves the AppCompat colorPrimary/colorAccent attributes,
         so the theme must descend from AppCompat and define them as opaque colors. -->
    <style name="Theme.ScreenCast" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryContainer">@color/primary_light</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorOnPrimaryContainer">@color/primary</item>
        <item name="colorAccent">@color/primary</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSurface">@color/card</item>
        <item name="colorOnSurface">@color/ink</item>
        <item name="colorOnSurfaceVariant">@color/muted</item>
        <item name="colorOutline">@color/hairline</item>
        <item name="android:colorBackground">@color/surface</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Widget.ScreenCast.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/card</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">2dp</item>
        <item name="contentPadding">22dp</item>
    </style>

    <style name="Widget.ScreenCast.Button" parent="Widget.Material3.Button">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="cornerRadius">16dp</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">10dp</item>
    </style>

    <style name="TextAppearance.ScreenCast.CardTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/ink</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="TextAppearance.ScreenCast.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/muted</item>
        <item name="android:textSize">15sp</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>
</resources>

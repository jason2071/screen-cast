<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Gradient hero. Bottom padding leaves room for the first card to overlap it. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="72dp"
            android:paddingEnd="24dp"
            android:paddingBottom="56dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_header_pill"
                android:drawableStart="@drawable/ic_tv"
                android:drawablePadding="8dp"
                android:paddingStart="14dp"
                android:paddingTop="7dp"
                android:paddingEnd="16dp"
                android:paddingBottom="7dp"
                android:text="@string/header_badge"
                android:textColor="@color/on_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:letterSpacing="-0.02"
                android:text="@string/header_title"
                android:textColor="@color/on_primary"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:alpha="0.88"
                android:lineSpacingExtra="4dp"
                android:text="@string/header_subtitle"
                android:textColor="@color/on_primary"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Miracast card, pulled up to overlap the hero. -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.ScreenCast.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="-32dp"
            android:layout_marginEnd="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_badge_primary"
                        android:contentDescription="@null"
                        android:padding="10dp"
                        android:src="@drawable/ic_screen_share" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mirror_title"
                            android:textAppearance="@style/TextAppearance.ScreenCast.CardTitle" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:letterSpacing="0.04"
                            android:text="@string/mirror_tag"
                            android:textColor="@color/primary"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/mirror_body"
                    android:textAppearance="@style/TextAppearance.ScreenCast.Body" />

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.ScreenCast.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:onClick="openCastSettings"
                    android:text="@string/mirror_action"
                    app:icon="@drawable/ic_tv"
                    app:iconTint="@color/on_primary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Google Cast card. -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.ScreenCast.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_badge_accent"
                        android:contentDescription="@null"
                        android:padding="10dp"
                        android:src="@drawable/ic_cast" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cast_title"
                            android:textAppearance="@style/TextAppearance.ScreenCast.CardTitle" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:letterSpacing="0.04"
                            android:text="@string/cast_tag"
                            android:textColor="@color/accent"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <androidx.mediarouter.app.MediaRouteButton
                        android:id="@+id/google_cast_button"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="@string/cast_button_description" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/cast_body"
                    android:textAppearance="@style/TextAppearance.ScreenCast.Body" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:hint="@string/cast_url_label"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusTopStart="16dp"
                    app:endIconMode="clear_text"
                    app:placeholderText="@string/cast_url_hint"
                    app:placeholderTextColor="@color/muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/media_url"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:autofillHints="url"
                        android:inputType="textUri"
                        android:maxLines="1"
                        android:textColor="@color/ink"
                        android:textColorHint="@color/muted"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.ScreenCast.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:onClick="castVideo"
                    android:text="@string/cast_action"
                    app:backgroundTint="@color/accent"
                    app:icon="@drawable/ic_play"
                    app:iconTint="@color/on_primary" />

                <!-- Local-file path: the app serves the picked video over Wi-Fi for the receiver. -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/hairline" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="12dp"
                        android:text="@string/local_divider"
                        android:textColor="@color/muted"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/hairline" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/local_body"
                    android:textAppearance="@style/TextAppearance.ScreenCast.Body" />

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:minHeight="56dp"
                    android:onClick="pickLocalVideo"
                    android:text="@string/local_pick"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/ic_folder"
                    app:iconPadding="10dp" />

                <TextView
                    android:id="@+id/local_video_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_badge_accent"
                    android:drawableStart="@drawable/ic_check"
                    android:drawablePadding="8dp"
                    android:ellipsize="middle"
                    android:maxLines="1"
                    android:padding="12dp"
                    android:textColor="@color/ink"
                    android:textSize="14sp"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/cast_local_button"
                    style="@style/Widget.ScreenCast.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:enabled="false"
                    android:onClick="castLocalVideo"
                    android:text="@string/local_cast"
                    app:backgroundTint="@color/accent"
                    app:icon="@drawable/ic_play"
                    app:iconTint="@color/on_primary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Numbered getting-started steps. -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="30dp"
            android:text="@string/steps_title"
            android:textColor="@color/ink"
            android:textSize="19sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="24dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:background="@drawable/bg_step_number"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:text="@string/step_1"
                    android:textColor="@color/muted"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:background="@drawable/bg_step_number"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:text="@string/step_2"
                    android:textColor="@color/muted"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:background="@drawable/bg_step_number"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:text="@string/step_3"
                    android:textColor="@color/muted"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:background="@drawable/bg_step_number"
                    android:gravity="center"
                    android:text="4"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:text="@string/step_4"
                    android:textColor="@color/muted"
                    android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="26dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="36dp"
            android:drawableStart="@drawable/ic_info"
            android:drawablePadding="10dp"
            android:lineSpacingExtra="3dp"
            android:text="@string/footnote"
            android:textColor="@color/muted"
            android:textSize="13sp" />
    </LinearLayout>
</ScrollView>
